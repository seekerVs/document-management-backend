PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,https://your-flutter-web-app.com
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-login@email.com
BREVO_SMTP_PASS=your-smtp-password
EMAIL_FROM_NAME=Scrivener
EMAIL_FROM_ADDRESS=your-brevo-login@email.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
API_SECRET_KEY=your_secret_key_here
