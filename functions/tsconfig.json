{
  "compilerOptions": {
    "module": "nodenext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "lib",
    "rootDir": "./src",
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "declaration": true,
    "declarationMap": true,
  },
  "compileOnSave": true,
  "include": ["./src",],
  "exclude": ["node_modules", "lib"]
}
